# Jadzia COI — environment template (copy to .env, never commit .env)

# Core
ANTHROPIC_API_KEY=
JWT_SECRET=
SSH_HOST=
SSH_USER=
SSH_PASSWORD=
SSH_KEY_PATH=
BASE_PATH=
TELEGRAM_BOT_TOKEN=

# Production gate — set on VPS (fail boot if secrets missing)
# JADZIA_ENV=production
# REQUIRE_SECRETS=1

# INT-002 WooCommerce webhook (must match zzpackage FG_JADZIA_WEBHOOK_SECRET)
WC_WEBHOOK_SECRET=

# INT-004 game leads (app.flexgrafik.nl X-API-Key)
LEADS_API_KEY=

# INT-009 GA4 analytics snapshot (VPS path — NOT /root/jadzia/ after OPS-01)
GOOGLE_APPLICATION_CREDENTIALS=/opt/jadzia/secrets/ga4-service-account.json
GA4_PROPERTY_ID_APP=
GA4_PROPERTY_ID_ZZPACKAGE=
GA4_CACHE_TTL_SECONDS=900

# INT-011 Facebook Page publish (Phase B.3)
FB_PAGE_ID=
FB_ACCESS_TOKEN=
# Optional: worker checks approved entries every N seconds (0 = disabled)
FB_PUBLISH_CHECK_INTERVAL_SECONDS=60

# Dev only — enable uvicorn reload when running python main.py locally
# UVICORN_RELOAD=1

# COI weekly brief (S3-02) — interval in seconds, 0 = disabled
# WEEKLY_BRIEF_INTERVAL_SECONDS=604800
