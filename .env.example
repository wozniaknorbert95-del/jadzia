# Jadzia COI — environment template (copy to .env, never commit .env)

# Core
ANTHROPIC_API_KEY=
JWT_SECRET=
SSH_HOST=
SSH_USER=
SSH_PASSWORD=
SSH_KEY_PATH=
BASE_PATH=
TELEGRAM_BOT_TOKEN=
# Internal Worker API URL (VPS default: http://127.0.0.1:8000)
# TELEGRAM_BOT_API_BASE_URL=http://127.0.0.1:8000
# Public HTTPS URL for Commander deeplinks from /ticket (mobile)
# JADZIA_PUBLIC_URL=https://api.zzpackage.flexgrafik.nl

# Production gate — set on VPS (fail boot if secrets missing)
# JADZIA_ENV=production
# REQUIRE_SECRETS=1

# INT-002 WooCommerce webhook (must match zzpackage FG_JADZIA_WEBHOOK_SECRET)
WC_WEBHOOK_SECRET=

# INT-004 game leads (app.flexgrafik.nl X-API-Key)
LEADS_API_KEY=

# INT-009 GA4 analytics snapshot (VPS path — NOT /root/jadzia/ after OPS-01)
GOOGLE_APPLICATION_CREDENTIALS=/opt/jadzia/secrets/ga4-service-account.json
GA4_PROPERTY_ID_APP=
GA4_PROPERTY_ID_ZZPACKAGE=
GA4_CACHE_TTL_SECONDS=900

# INT-011 Facebook Page publish (Phase B.3)
FB_PAGE_ID=
FB_ACCESS_TOKEN=
# App credentials — VPS only (never commit). Required for long-lived token exchange.
FB_APP_ID=
FB_APP_SECRET=
# Optional: worker checks approved entries every N seconds (0 = disabled)
FB_PUBLISH_CHECK_INTERVAL_SECONDS=60

# Dev only — enable uvicorn reload when running python main.py locally
# UVICORN_RELOAD=1

# COI weekly brief (S3-02) — interval in seconds, 0 = disabled
# WEEKLY_BRIEF_INTERVAL_SECONDS=604800

# MKT-BRAIN-PRO F0 — Data Truth Layer scheduled ingest (0 = disabled)
# MARKETING_DTL_INGEST_INTERVAL_SECONDS=3600
# Optional override for L0 HTML pixel probe
# DTL_L0_PROBE_URL=https://zzpackage.flexgrafik.nl/wizard/

# MKT-BRAIN-PRO F1 — Marketing Brain cycle (0 = disabled); MB_MODE=shadow|propose|act
# MARKETING_BRAIN_INTERVAL_SECONDS=3600
# MB_MODE=shadow

# MKT-BRAIN-PRO F3 — Brain Bus webhook (VCMS/KODA → POST /api/v1/brain-bus/events)
# Header: X-Brain-Bus-Secret
# BRAIN_BUS_SECRET=

# MKT-BRAIN-PRO F2b — Campaign Vector Memory (Chroma persistent path)
# MB_CHROMA_PATH=data/chroma/marketing

# COI Commander — SMTP escalation to Delegat (COI-CMD-SMTP-01)
# Optional: without SMTP_HOST email is skipped (TG still works).
# Gmail: App Password (Google Account → Security → 2FA → App passwords).
# Playbook: docs/ops/SMTP-DELEGAT-ESCALATION.md
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=

# Design Agent (VGE 3.0 mockup generation for zzpackage)
# VGE_ROOT=/opt/vge/image-generator
# ZZPACKAGE_SSOT_PATH=/opt/zzpackage/system/data/product-master-table.json
# DESIGN_AGENT_OUTPUT_DIR=/var/www/design-agent-uploads
# DESIGN_AGENT_PUBLIC_URL=https://api.zzpackage.flexgrafik.nl/uploads/design-agent
# DESIGN_AGENT_MOCKUP_PUBLIC_BASE=  # alias for PUBLIC_URL
# INSPIRE_MOCKUP_OCR=1
# FG_DESIGN_AGENT_KEY=
# DA_CHAT_RATE_LIMIT=200
# DA_RATE_STORE_PATH=/var/lib/jadzia/da-rate-store.json
# OPENROUTER_API_KEY=
# DESIGN_AGENT_ENABLE_PHOTOREAL=0
# DESIGN_AGENT_QA_STRICT=1
